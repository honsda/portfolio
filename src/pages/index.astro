---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import BottomStrip from '../components/BottomStrip.astro';
import Marquee from '../components/Marquee.svelte';
import Footer from '../components/Footer.astro';
import About from '../components/About.astro';
import Projects from '../components/Projects.astro';
import Stack from '../components/Stack.astro';
import Contact from '../components/Contact.astro';

const marqueeItems = [
  'Svelte', 'Astro', 'Vue.js', 'React', 'TypeScript', 
  'JavaScript', 'Figma', 'MapLibre', 'QGIS', 'Java', 'Open Source'
];
---

<Base title="honsda | Portfolio">
	<Nav />
	
	<main>
		<Hero />
		<BottomStrip />
		<Marquee client:visible items={marqueeItems} />
		<About />
		<Projects />
		<Stack />
		<Contact />
	</main>

	<Footer />
</Base>
