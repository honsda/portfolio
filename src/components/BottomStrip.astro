---
<div class="border-t border-white/5 bg-ink-black py-8">
  <div class="max-w-[1440px] mx-auto px-10 flex flex-col md:flex-row items-start md:items-center justify-between gap-8">
    <p class="font-mono text-[10.5px] text-[#aaaaaa] leading-relaxed max-w-xl">
      Based in Surabaya, Indonesia. Designing and building web experiences — 
      aiming to be a fullstack dev, makes cool stuff, yea
    </p>

    <div class="flex items-center gap-4">
      <a 
        href="#projects" 
        class="bg-paper text-ink-black font-mono text-[9px] uppercase tracking-[0.2em] px-6 py-3 transition-colors duration-300 hover:bg-paper-mid"
      >
        See my work
      </a>
      <button 
        id="copy-email-strip"
        data-email="moehd.abdullah@gmail.com"
        class="border border-paper-ghost text-paper-ghost font-mono text-[9px] uppercase tracking-[0.2em] px-6 py-3 transition-all duration-300 hover:border-paper hover:text-paper"
      >
        Get in touch
      </button>
    </div>
  </div>
</div>

<script>
  const btnStrip = document.getElementById('copy-email-strip');
  btnStrip?.addEventListener('click', () => {
    const email = btnStrip.getAttribute('data-email') || "";
    navigator.clipboard.writeText(email);
    
    const originalText = btnStrip.innerText;
    btnStrip.innerText = "Copied!";
    
    // Open mail client
    setTimeout(() => {
      window.location.href = `mailto:${email}`;
    }, 100);

    setTimeout(() => {
      btnStrip.innerText = originalText;
    }, 2000);
  });
</script>
