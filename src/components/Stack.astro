  {
    category: "Frameworks",
    items: [
      { name: "Svelte", icon: "svelte", highlighted: true },
      { name: "Astro", icon: "astro", highlighted: true },
      { name: "Vue.js", icon: "vue", highlighted: true },
      { name: "React", icon: "react", highlighted: true }
    ]
  },
  {
    category: "Language",
    items: [
      { name: "TypeScript", icon: "typescript", highlighted: true },
      { name: "JavaScript", icon: "javascript" },
      { name: "Java", icon: "java" }
    ]
  },
  {
    category: "Mapping",
    items: [
      { name: "MapLibre", icon: "map", highlighted: true },
      { name: "QGIS", icon: "globe", highlighted: true }
    ]
  },
  {
    category: "Design",
    items: [
      { name: "Figma", icon: "figma", highlighted: true }
    ]
  },
  {
    category: "Tooling",
    items: [
      { name: "Git", icon: "git" },
      { name: "GitHub", icon: "github" }
    ]
  },
  {
    category: "AI Workflow",
    dimmed: true,
    items: [
      { name: "Claude", icon: "bot" },
      { name: "Gemini CLI", icon: "terminal" },
      { name: "Kimi", icon: "sparkles" }
    ]
