---
import StackCLI from './StackCLI.svelte';
import LazyLoad from './LazyLoad.svelte';

const stack = [
  {
    category: "Frameworks",
    items: [
      { name: "Svelte", icon: "devicon-svelte-plain", highlighted: true },
      { name: "Astro", icon: "devicon-astro-plain", highlighted: true },
      { name: "Vue.js", icon: "devicon-vuejs-plain", highlighted: true },
      { name: "React", icon: "devicon-react-original", highlighted: true }
    ]
  },
  {
    category: "Language",
    items: [
      { name: "TypeScript", icon: "devicon-typescript-plain", highlighted: true },
      { name: "JavaScript", icon: "devicon-javascript-plain" },
      { name: "Python", icon: "devicon-python-plain" },
      { name: "C++", icon: "devicon-cplusplus-plain" },
      { name: "Java", icon: "devicon-java-plain" }
    ]
  },
  {
    category: "Mapping",
    items: [
      { name: "MapLibre", icon: "devicon-matcha-plain", highlighted: true },
      { name: "QGIS", icon: "devicon-qgis-plain", highlighted: true }
    ]
  },
  {
    category: "Design",
    items: [
      { name: "Figma", icon: "devicon-figma-plain", highlighted: true }
    ]
  },
  {
    category: "Tooling",
    items: [
      { name: "Git", icon: "devicon-git-plain" },
      { name: "GitHub", icon: "devicon-github-original" }
    ]
  },
  {
    category: "AI Workflow",
    dimmed: true,
    items: [
      { name: "Claude", icon: "devicon-anthropic-plain" },
      { name: "Gemini CLI", icon: "devicon-google-plain" },
      { name: "Kimi", icon: "devicon-moon-plain" }
    ]
  }
];
---
<section id="stack" class="bg-ink-deep border-t border-b border-white/5 py-32">
  <div class="max-w-[1440px] mx-auto px-10">
    <span class="section-label fade-up">// Stack</span>
    
    <div class="flex flex-col lg:flex-row lg:items-start justify-between gap-12 mb-12 lg:mb-0">
      <h2 class="text-[clamp(2.5rem,6vw,3.5rem)] font-black leading-none fade-up">
        Tools I<br />
        work with.
      </h2>

      <div class="fade-up w-full lg:w-[50%]" style="animation-delay: 0.2s;">
        <div class="h-[180px] w-full relative z-30 translate-y-0 lg:translate-y-[18px]">
          <LazyLoad client:load>
            <div class="min-h-[180px]">
              <StackCLI client:load />
            </div>
          </LazyLoad>
        </div>
      </div>
    </div>

    <div class="border-t border-white/5">
      {stack.map((group) => (
        <div class={`flex flex-col md:flex-row border-b border-white/5 py-8 group transition-colors duration-300 fade-up ${group.dimmed ? 'opacity-40' : ''}`}>
          <div class={`w-[110px] shrink-0 font-mono text-[8.5px] uppercase tracking-[0.2em] mb-4 md:mb-0 ${group.dimmed ? 'text-indigo-faint' : 'text-indigo-muted'}`}>
            {group.category}
          </div>
          <div class="flex flex-wrap gap-x-6 gap-y-4">
            {group.items.map((item) => (
              <div class={`flex items-center gap-2 font-mono text-[9.5px] uppercase tracking-[0.1em] transition-colors duration-300 ${
                group.dimmed 
                  ? 'text-indigo-muted' 
                  : (item.highlighted ? 'text-paper-mid group-hover:text-paper' : 'text-paper-dim')
              }`}>
                <i class={`${item.icon} text-[14px]`}></i>
                <span>{item.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
