---
<section id="stack" class="bg-ink-deep border-t border-b border-white/5 py-32">
  <div class="max-w-[1440px] mx-auto px-10">
    <span class="section-label fade-up">// Stack</span>
    
    <h2 class="text-[clamp(2.5rem,6vw,3.5rem)] font-black leading-none mb-20 fade-up">
      Tools I<br />
      work with.
    </h2>

    <div class="border-t border-white/5">
      {stack.map((group) => (
        <div class={`flex flex-col md:flex-row border-b border-white/5 py-8 group transition-colors duration-300 fade-up ${group.dimmed ? 'opacity-30' : ''}`}>
          <div class={`w-[110px] shrink-0 font-mono text-[8.5px] uppercase tracking-[0.2em] mb-4 md:mb-0 ${group.dimmed ? 'text-[#1e1e26]' : 'text-indigo-muted'}`}>
            {group.category}
          </div>
          <div class="flex flex-wrap gap-x-6 gap-y-4">
            {group.items.map((item) => (
              <div class={`flex items-center gap-2 font-mono text-[9.5px] uppercase tracking-[0.1em] transition-colors duration-300 ${
                group.dimmed 
                  ? 'text-[#252530]' 
                  : (item.highlighted ? 'text-paper-mid group-hover:text-paper' : 'text-[#999999]')
              }`}>
                <Fragment set:html={icons[item.icon]} />
                <span>{item.name}</span>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
