---
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---
<footer class="border-t border-white/5 bg-ink-black py-12">
  <div class="max-w-[1440px] mx-auto px-10 flex flex-col md:flex-row items-center justify-between gap-6">
    <div class="h-10 opacity-10">
      <img src={`${base}/assets/honsdainsignajava.svg`} alt="honsda insignia" class="h-full w-auto object-contain" />
    </div>

    <div class="font-mono text-[8.5px] text-paper-ghost uppercase tracking-[0.2em] flex flex-col md:flex-row items-center gap-4 md:gap-8 text-center md:text-right">
      <span>Surabaya, Indonesia</span>
      <span class="hidden md:inline text-white/5">•</span>
      <span>made with love by honsda</span>
      <span class="hidden md:inline text-white/5">•</span>
      <span>© 2026</span>
    </div>
  </div>
</footer>
