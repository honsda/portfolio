---
import GushingLeaves from './GushingLeaves.svelte';
---
<section id="about" class="relative max-w-[1440px] mx-auto px-10 py-32">
  <style>
    #about strong {
      color: #bbbbbb;
    }
  </style>

  <span class="section-label fade-up">// About</span>

  <div class="relative">
    <!-- Integrated Profile Image -->
    <div class="profile-image-container absolute top-0 right-0 pr-16 hidden lg:block fade-up pointer-events-none">
      <div class="relative group">
        <!-- Ambient Glow -->
        <div class="absolute inset-0 bg-indigo opacity-20 blur-[50px] rounded-full group-hover:opacity-30 transition-opacity duration-700"></div>
        
        <div class="relative">
          <img 
            src="https://github.com/honsda.png" 
            alt="honsda" 
            class="w-56 h-56 lg:w-64 lg:h-64 object-cover grayscale brightness-90 transition-all duration-700"
            onerror="this.closest('.profile-image-container').style.display='none'"
            style="
              opacity: 0.75;
              mask-image: radial-gradient(circle at center, black 15%, transparent 80%);
              -webkit-mask-image: radial-gradient(circle at center, black 15%, transparent 80%);
              filter: grayscale(1) brightness(1) contrast(1.1);
            "
          />
        </div>
      </div>
    </div>

    <!-- Gushing Leaves positioned relative to title -->
    <div class="absolute -top-2 left-0 w-full h-64 z-0 pointer-events-none overflow-hidden">
      <GushingLeaves client:visible />
    </div>

    <h2 class="relative z-10 text-[clamp(2.5rem,6vw,3.5rem)] font-black leading-none mb-4 fade-up">
      Developer.<br />
      Designer.<br />
      Builder.
    </h2>
    <p class="relative z-10 fade-up font-mono text-[10px] text-[#bbbbbb] mb-16 uppercase tracking-[0.4em]">Muhammad Abdullah</p>
  </div>

  <div class="relative z-10 grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-24">
    <!-- Left — Bio -->
    <div class="space-y-8 font-mono text-[10px] text-[#999999] leading-[1.9] fade-up">
      <div class="flex flex-col gap-1">
        <p>hey, call me hons</p>
        <p class="text-[8px] opacity-40 tracking-widest">or call me abdullah</p>
      </div>
      <p>
        I'm a <strong>computer engineering student</strong> at <strong><a href="https://its.ac.id" target="_blank" rel="noopener noreferrer" class="text-indigo hover:text-white underline decoration-white/20 underline-offset-4 transition-all">Institut Teknologi Sepuluh Nopember (ITS)</a></strong> and frontend developer working across frameworks, 

        mapping tools, and design systems. I've been shipping real things 
        on the web for years before AI tools existed, and sharper 
        because of them now.
      </p>
      <p>
        From political simulators to wiki bots to live event platforms. 
        I own projects end to end, from concept and Figma to deployed code.
      </p>
      <p>
        Design sensibility and technical depth in the same person. I build with 
        modern tools and AI-assisted workflows to move fast without losing what's under the hood.
      </p>
      <p>
        so like yk get me riled up fr
      </p>
      <p>these stuff are part of my hobbies. it gets me fired up with these projects, so don't doubt my effort. aside from that its just learning languages, history, and cultures. and doing calisthenics.</p>
    </div>

    <!-- Right — Stats Grid -->
    <div class="grid grid-cols-2 gap-px bg-white/5 border border-white/5 fade-up">
      {[
        { val: '5+', label: 'Projects shipped' },
        { val: '3+', label: 'Years building' },
        { val: '6+', label: 'Frameworks used' },
        { val: '∞', label: 'Tabs open' },
      ].map((stat) => (
        <div class="bg-ink-surface p-8 flex flex-col justify-center items-center text-center">
          <span class="font-display text-3xl font-bold text-paper mb-2">{stat.val}</span>
          <span class="font-mono text-[8.5px] uppercase tracking-[0.2em] text-paper-ghost">{stat.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>
