---
import { Icon } from 'astro-icon/components';
const base = import.meta.env.BASE_URL === '/' ? '' : import.meta.env.BASE_URL;
---
<nav class="fixed top-0 left-0 right-0 z-[100] border-b border-white/5 bg-ink-black/80 backdrop-blur-md">
  <div class="max-w-[1440px] mx-auto px-6 md:px-10 h-20 flex items-center justify-between">
    <div class="flex items-center gap-4">
      <img src={`${base}/assets/honsdainsignajava.svg`} alt="honsda insignia" class="h-10 w-auto object-contain" />
      <span class="font-mono text-[9px] text-paper-ghost uppercase tracking-[0.25em]">honsda</span>
    </div>

    <div class="hidden md:flex items-center gap-8">
      {['About', 'Projects', 'Stack', 'Contact'].map((item) => (
        <a 
          href={`#${item.toLowerCase()}`} 
          class="font-mono text-[10px] uppercase tracking-[0.2em] text-paper-ghost hover:text-paper transition-colors duration-300"
        >
          {item}
        </a>
      ))}
    </div>

    <button class="md:hidden font-mono text-[10px] text-paper-ghost uppercase tracking-[0.2em] flex items-center gap-2">
      <Icon name="iconoir:menu" class="w-4 h-4" />
      <span>Menu</span>
    </button>
  </div>
</nav>
