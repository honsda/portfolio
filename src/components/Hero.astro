---
---
<section class="relative h-screen min-h-[700px] w-full bg-ink-black overflow-hidden flex items-end">
  <!-- Hero Art Background Layer -->
  <div class="hero-art">
    <img 
      src="/assets/mountains-placeholder.svg" 
      alt="" 
      class="mountain-img" 
      aria-hidden="true" 
    />
  </div>

  <div class="relative z-10 w-full max-w-[1440px] mx-auto px-10 pb-20">
    <div class="max-w-2xl">
      <span class="block font-mono text-[9.5px] text-indigo-DEFAULT uppercase tracking-[0.22em] mb-4 overflow-hidden">
        <span class="inline-block animate-fade-up">
          — honsda / frontend / UI/UX
        </span>
      </span>

      <h1 class="font-display font-black leading-[0.9] text-[clamp(3rem,8vw,4.2rem)] flex flex-col">
        <span class="line-1 text-transparent opacity-0 animate-fade-up" style="-webkit-text-stroke: 1.2px rgba(232,228,220,0.25); animation-delay: 0.15s;">
          interfaces
        </span>
        <span class="line-2 text-paper opacity-0 animate-fade-up" style="animation-delay: 0.3s;">
          built with
        </span>
        <span class="line-3 text-indigo-DEFAULT opacity-0 animate-fade-up" style="animation-delay: 0.45s;">
          intention.
        </span>
      </h1>
    </div>
  </div>
</section>

<!--
  MOUNTAIN ART SWAP
  Replace /public/assets/mountains-placeholder.svg with your own ink PNG.
  The CSS mix-blend-mode: lighten handles compositing automatically:
  black in your image disappears into the dark bg, light strokes stay visible.
  Any ink painting with black strokes on white or transparent bg works.
  Adjust opacity on .mountain-img (0.7–1.0) to taste.
-->

<style>
  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .animate-fade-up {
    animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
</style>
