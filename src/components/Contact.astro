<section id="contact" class="max-w-2xl mx-auto px-10 py-48 text-center flex flex-col items-center">
  <span class="section-label fade-up">// Contact</span>
  
  <h2 class="text-[clamp(2.5rem,6vw,3.5rem)] font-black leading-none mb-8 fade-up">
    Let's work<br />
    together.
  </h2>

  <p class="font-mono text-[10px] text-[#888888] leading-[1.9] mb-12 fade-up max-w-lg">
    Open to remote part-time work — frontend development, UI/UX, spatial web. Based in Surabaya, Indonesia. Async-friendly.
  </p>

  <div class="flex flex-col sm:flex-row items-center gap-4 fade-up">
    <a 
      href="https://github.com/honsda" 
      target="_blank" 
      rel="noopener noreferrer"
      class="bg-paper text-ink-black font-mono text-[9px] uppercase tracking-[0.2em] px-10 py-4 transition-colors duration-300 hover:bg-paper-mid w-full sm:w-auto"
    >
      GitHub
    </a>
    <a 
      href="mailto:your@email.com" 
      class="border border-paper-ghost text-paper-ghost font-mono text-[9px] uppercase tracking-[0.2em] px-10 py-4 transition-all duration-300 hover:border-paper hover:text-paper w-full sm:w-auto"
    >
      Email me
    </a>
  </div>
</section>
